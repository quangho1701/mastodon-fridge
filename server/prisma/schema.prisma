generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")

  scannedEvents Event[]       @relation("ScannedByUser")
  fridgeItems   FridgeItem[]
  galleryMedia  GalleryMedia[]
  stickers      Sticker[]

  @@map("users")
}

model Event {
  id             String   @id @default(uuid())
  title          String
  date           DateTime
  startTime      String?  @map("start_time")
  endTime        String?  @map("end_time")
  location       String?
  description    String?
  organizer      String?
  flyerImageUrl  String?  @map("flyer_image_url")
  scannedByUser  User?    @relation("ScannedByUser", fields: [scannedByUserId], references: [id])
  scannedByUserId String? @map("scanned_by_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  fridgeItems  FridgeItem[]
  galleryMedia GalleryMedia[]

  @@map("events")
}

model FridgeItem {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @map("user_id")
  event       Event    @relation(fields: [eventId], references: [id])
  eventId     String   @map("event_id")
  stickerType String?  @map("sticker_type")
  stickerId   String?  @map("sticker_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("fridge_items")
}

model GalleryMedia {
  id             String   @id @default(uuid())
  event          Event    @relation(fields: [eventId], references: [id])
  eventId        String   @map("event_id")
  uploadedByUser User     @relation(fields: [uploadedByUserId], references: [id])
  uploadedByUserId String @map("uploaded_by_user_id")
  mediaUrl       String   @map("media_url")
  mediaType      String   @map("media_type")
  createdAt      DateTime @default(now()) @map("created_at")

  stickers Sticker[]

  @@map("gallery_media")
}

model Sticker {
  id           String       @id @default(uuid())
  mediaItem    GalleryMedia @relation(fields: [mediaItemId], references: [id])
  mediaItemId  String       @map("media_item_id")
  placedByUser User         @relation(fields: [placedByUserId], references: [id])
  placedByUserId String     @map("placed_by_user_id")
  stickerType  String       @map("sticker_type")
  xPos         Float        @map("x_pos")
  yPos         Float        @map("y_pos")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("stickers")
}
